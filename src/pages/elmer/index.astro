---
import Base from "@/layouts/Base.astro";
import ImageMod from "@/components/ImageMod.astro";
---

<Base
  title="Find an Elmer"
  meta_title="KARC - Find an Elmer"
  description="New to amateur radio? KARC members are happy to mentor any skill level across VHF/UHF, HF, digital modes, and more."
>
  <section class="hero-heroimg relative">
    <div class="container mx-auto px-6 py-16 text-center">
      <h1 class="text-4xl font-extrabold mb-4">Find an Elmer</h1>
      <p class="text-lg text-white/80 max-w-2xl mx-auto">
        An "Elmer" is a ham who mentors other operators — helping them get on the air, learn new modes, or tackle their next project.
      </p>
    </div>
  </section>

  <section class="section-md">
    <div class="max-w-[1000px] mx-auto px-6 space-y-8">

      <article class="w4-card p-6 space-y-3">
        <h2 class="text-xl font-bold text-white">We Can Help</h2>
        <p class="text-sm text-white/75">
          KARC has members willing to elmer operators at any skill level — from brand-new Technicians to upgrading General and Extra class operators. Whatever you want to learn, someone in the club has been there and is happy to help.
        </p>
        <p class="text-sm text-white/75">
          Areas our members cover include:
        </p>
        <ul class="list-disc list-inside text-sm text-white/80 space-y-2">
          <li>VHF/UHF — repeaters, simplex, weak signal, satellite</li>
          <li>HF — getting on the air, antenna selection, operating practices</li>
          <li>Digital modes — FT8/FT4, JS8Call, Winlink, WSPR, and more</li>
          <li>CW — learning Morse code, building speed, operating on the bands</li>
          <li>POTA and SOTA — portable and field operating</li>
          <li>Fox hunting and direction finding</li>
          <li>Antenna building and RF fundamentals</li>
          <li>Logging software and contesting</li>
        </ul>
      </article>

      <article class="w4-card p-6 space-y-3">
        <h2 class="text-xl font-bold text-white">How to Get Connected</h2>
        <p class="text-sm text-white/75">
          Reach out through our contact page and let us know what you are hoping to learn or work on. We will put you in touch with a club member who can help.
        </p>
        <a class="btn btn-primary inline-flex items-center justify-center px-4 py-2 mt-2 text-sm font-semibold" href="/contact/">
          Contact the Club
        </a>
      </article>

      <article class="w4-card p-6 space-y-3">
        <h2 class="text-xl font-bold text-white">Want to Be an Elmer?</h2>
        <p class="text-sm text-white/75">
          If you are an experienced operator interested in mentoring newer hams, we would love to hear from you. Reach out and let us know what areas you are comfortable teaching.
        </p>
        <a class="btn btn-primary inline-flex items-center justify-center px-4 py-2 mt-2 text-sm font-semibold" href="/contact/">
          Get in Touch
        </a>
      </article>

    </div>
  </section>
</Base>
