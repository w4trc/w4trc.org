---
import Base from "@/layouts/Base.astro";
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import type { ImageMetadata } from "astro";

export async function getStaticPaths() {
  const all = await getCollection("posts", ({ data }) => !data.draft);
  return all.map((p) => ({
    params: { slug: p.id.replace(/\/index$/, "") },
    props: { post: p },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;

const fmtDate = (iso: string) =>
  new Date(iso + "T00:00:00").toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });

// Collect gallery images for this post's gallery/ subfolder
const allGalleryModules = import.meta.glob<{ default: ImageMetadata }>(
  "../../content/posts/**/gallery/*.{jpg,jpeg,png,webp,gif,JPG,JPEG,PNG}",
  { eager: true }
);

const postFolder = post.id.replace(/\/index$/, "");
const galleryImages = Object.entries(allGalleryModules)
  .filter(([path]) => path.includes(`/${postFolder}/gallery/`))
  .map(([_, mod]) => mod.default);
---

<Base
  title={d.title}
  meta_title={`W4TRC - ${d.title}`}
  description={d.summary}
  image={d.image ?? "/images/KARC-SEOImage.png"}
>
  <section class="hero-heroimg relative">
    <div class="container mx-auto px-6 py-16 text-center">
      <p class="text-sm text-white/60 mb-2 font-mono">
        <time datetime={d.date}>{fmtDate(d.date)}</time>
        {d.author && <span> &middot; {d.author}</span>}
      </p>
      <h1 class="text-4xl font-extrabold mb-3">{d.title}</h1>
      {d.summary && (
        <p class="text-base text-white/75 max-w-2xl mx-auto mt-2">{d.summary}</p>
      )}
      {d.tags && d.tags.length > 0 && (
        <div class="flex justify-center gap-2 mt-4 flex-wrap">
          {d.tags.map((tag) => (
            <span class="text-xs font-bold uppercase tracking-wider px-3 py-1 rounded bg-[var(--w4-accent)]/20 text-[var(--w4-accent)]">
              {tag.replace(/-/g, " ")}
            </span>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="section-md">
    <div class="max-w-[800px] mx-auto px-6 space-y-8">

      {d.image && (
        <div class="w4-card overflow-hidden">
          <img
            src={d.image}
            alt={d.title}
            class="w-full h-64 object-cover"
            loading="lazy"
          />
        </div>
      )}

      <article class="w4-card p-6">
        <div class="prose prose-invert max-w-none">
          <Content />
        </div>
      </article>

      {galleryImages.length > 0 && (
        <div class="w4-card p-6 space-y-4">
          <h2 class="text-xl font-bold text-white">Photos</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {galleryImages.map((img, i) => (
              <button
                class="gallery-thumb overflow-hidden rounded-lg aspect-square cursor-zoom-in focus:outline-none focus:ring-2 focus:ring-[var(--w4-accent)]"
                data-index={i}
                aria-label={`Open photo ${i + 1}`}
              >
                <Image
                  src={img}
                  alt={`Field Day photo ${i + 1}`}
                  width={400}
                  height={400}
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-200"
                  loading="lazy"
                />
              </button>
            ))}
          </div>
        </div>
      )}

      <div>
        <a
          class="inline-flex items-center gap-2 text-[var(--w4-accent)] font-semibold hover:underline underline-offset-4"
          href="/posts/"
        >
          <span aria-hidden="true">←</span>
          All posts
        </a>
      </div>

    </div>
  </section>

  {galleryImages.length > 0 && (
    <>
      <!-- Lightbox -->
      <div
        id="lightbox"
        class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90"
        role="dialog"
        aria-modal="true"
        aria-label="Photo lightbox"
      >
        <button
          id="lb-close"
          class="absolute top-4 right-4 text-white/70 hover:text-white text-3xl leading-none"
          aria-label="Close"
        >
          ×
        </button>
        <button
          id="lb-prev"
          class="absolute left-4 text-white/70 hover:text-white text-4xl leading-none px-2"
          aria-label="Previous photo"
        >
          ‹
        </button>
        <img
          id="lb-img"
          src=""
          alt=""
          class="max-h-[90vh] max-w-[90vw] object-contain rounded-lg"
        />
        <button
          id="lb-next"
          class="absolute right-4 text-white/70 hover:text-white text-4xl leading-none px-2"
          aria-label="Next photo"
        >
          ›
        </button>
        <p id="lb-counter" class="absolute bottom-4 text-white/50 text-sm tabular-nums"></p>
      </div>

      <script define:vars={{ srcs: galleryImages.map((img) => img.src) }}>
        const lb = document.getElementById("lightbox");
        const lbImg = document.getElementById("lb-img");
        const lbCounter = document.getElementById("lb-counter");
        let current = 0;

        function show(i) {
          current = (i + srcs.length) % srcs.length;
          lbImg.src = srcs[current];
          lbImg.alt = `Photo ${current + 1}`;
          lbCounter.textContent = `${current + 1} / ${srcs.length}`;
        }

        function open(i) {
          show(i);
          lb.classList.remove("hidden");
          lb.classList.add("flex");
          document.body.style.overflow = "hidden";
        }

        function close() {
          lb.classList.add("hidden");
          lb.classList.remove("flex");
          document.body.style.overflow = "";
        }

        document.querySelectorAll(".gallery-thumb").forEach((btn) => {
          btn.addEventListener("click", () => open(Number(btn.dataset.index)));
        });

        document.getElementById("lb-close").addEventListener("click", close);
        document.getElementById("lb-prev").addEventListener("click", () => show(current - 1));
        document.getElementById("lb-next").addEventListener("click", () => show(current + 1));

        lb.addEventListener("click", (e) => { if (e.target === lb) close(); });

        document.addEventListener("keydown", (e) => {
          if (lb.classList.contains("hidden")) return;
          if (e.key === "Escape") close();
          if (e.key === "ArrowLeft") show(current - 1);
          if (e.key === "ArrowRight") show(current + 1);
        });
      </script>
    </>
  )}
</Base>
