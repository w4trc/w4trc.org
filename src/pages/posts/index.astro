---
import Base from "@/layouts/Base.astro";
import { getCollection } from "astro:content";

const all = await getCollection("posts", ({ data }) => !data.draft);

const posts = all.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const fmtDate = (iso: string) =>
  new Date(iso + "T00:00:00").toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<Base
  title="Posts"
  meta_title="W4TRC - Club Posts"
  description="Event recaps, news, and updates from the Knoxville Amateur Radio Club."
>
  <section class="hero-heroimg relative">
    <div class="container mx-auto px-6 py-16 text-center">
      <h1 class="text-4xl font-extrabold mb-3">Club Posts</h1>
      <p class="text-lg text-white/80 max-w-2xl mx-auto">
        Event recaps, news, and updates from W4TRC.
      </p>
    </div>
  </section>

  <section class="section-md">
    <div class="max-w-[1200px] mx-auto px-6 space-y-8">
      {posts.length === 0 ? (
        <div class="w4-card p-8 text-center">
          <p class="text-white/60">No posts yet. Check back soon!</p>
        </div>
      ) : (
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {posts.map((post) => (
            <article class="w4-card p-6 flex flex-col gap-3">
              <div class="flex items-center gap-2 flex-wrap">
                <time
                  datetime={post.data.date}
                  class="text-xs text-white/50 font-mono"
                >
                  {fmtDate(post.data.date)}
                </time>
                {post.data.tags?.map((tag) => (
                  <span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded bg-[var(--w4-accent)]/20 text-[var(--w4-accent)]">
                    {tag.replace(/-/g, " ")}
                  </span>
                ))}
              </div>

              <h2 class="text-xl font-bold text-white leading-snug">
                {post.data.title}
              </h2>

              {post.data.author && (
                <p class="text-sm text-[var(--w4-accent)] font-medium">
                  {post.data.author}
                </p>
              )}

              {post.data.summary && (
                <p class="text-sm text-white/75 line-clamp-3">
                  {post.data.summary}
                </p>
              )}

              <a
                class="inline-flex items-center gap-2 text-[var(--w4-accent)] font-semibold mt-auto hover:underline underline-offset-4"
                href={`/posts/${post.id.replace(/\/index$/, "")}/`}
              >
                Read more
                <span aria-hidden="true">→</span>
              </a>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</Base>
