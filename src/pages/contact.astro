---
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import ImageMod from "@/components/ImageMod.astro";

const title = "Contact Us";
const meta_title = "Contact - Kingsport Amateur Radio Club";
const description = "Get in touch with the Kingsport Amateur Radio Club (W4TRC).";
const image = "";

const { contact_form_action }: { contact_form_action: string } = config.params;
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
>
  <section class="hero-heroimg relative">
    <div class="container mx-auto px-6 py-16 text-center">
      {image && (
        <div aria-hidden="true" class="absolute inset-0 -z-10">
          <ImageMod
            src={image}
            width={1200}
            height={380}
            alt={title}
            format="webp"
            class="w-full h-full object-cover opacity-60"
          />
        </div>
      )}
      <h1 class="text-4xl font-extrabold mb-4">{title}</h1>
      {description && <p class="text-lg max-w-2xl mx-auto">{description}</p>}
    </div>
  </section>
  <section class="section-sm pb-0">
    <div class="container">
      <div class="row">
        <div class="mx-auto md:col-10 lg:col-6">
          <div class="mb-8 rounded-lg border border-blue-200 bg-blue-50 px-6 py-4 text-center dark:border-blue-800 dark:bg-blue-950">
            <p class="text-base">
              Have comments or suggestions? Submit them anonymously to the KARC board at{" "}
              <a href="https://forms.w4trc.org/comments" class="font-medium underline hover:no-underline">
                forms.w4trc.org/comments
              </a>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="section-sm">
    <div class="container">
      <div class="row">
        <div class="mx-auto md:col-10 lg:col-6">
          <form action={contact_form_action} method="POST">
            <div class="mb-6">
              <label for="name" class="form-label">
                Full Name <span class="text-red-500">*</span>
              </label>
              <input
                id="name"
                name="name"
                class="form-input"
                placeholder="John Doe"
                type="text"
                required
              />
            </div>
            <div class="mb-6">
              <label for="email" class="form-label">
                Email Address <span class="text-red-500">*</span>
              </label>
              <input
                id="email"
                name="email"
                class="form-input"
                placeholder="john.doe@email.com"
                type="email"
                required
              />
            </div>
            <div class="mb-6">
              <label for="message" class="form-label">
                Message <span class="text-red-500">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                class="form-input"
                placeholder="Message goes here..."
                required
                rows="8"></textarea>
            </div>
            <button type="submit" class="btn btn-white">Submit</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Base>
