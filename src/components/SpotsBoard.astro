---
// Client-side only — no server fetch; data changes every minute
---

<div id="spots-board" class="spots-board">
  <div id="spots-loading" class="spots-status">Loading spots&hellip;</div>
  <div id="spots-error" class="spots-status spots-error" hidden>
    Could not load spots. Will retry in 60 seconds.
  </div>
  <div id="spots-empty" class="spots-status" hidden>
    No members spotted on the air recently.
  </div>

  <div id="spots-wrap" hidden>
    <!-- Desktop table -->
    <div class="spots-scroll">
      <table class="spots-table" id="spots-table">
        <thead>
          <tr>
            <th>Member</th>
            <th>Freq&nbsp;/&nbsp;Band</th>
            <th>Mode</th>
            <th>Source</th>
            <th class="col-where">Where</th>
            <th class="col-heard">Heard&nbsp;by</th>
            <th>When</th>
          </tr>
        </thead>
        <tbody id="spots-body"></tbody>
      </table>
    </div>

    <!-- Mobile cards (populated by same JS) -->
    <ul id="spots-cards" class="spots-cards" aria-hidden="true"></ul>

    <p id="spots-updated" class="spots-updated"></p>
  </div>
</div>

<style>
  /* ── Status states ───────────────────────────────── */
  .spots-status {
    padding: 2.5rem 1rem;
    text-align: center;
    color: rgba(229, 231, 235, 0.55);
    font-style: italic;
  }
  .spots-error { color: #f87171; }

  /* ── Desktop table ───────────────────────────────── */
  .spots-scroll {
    overflow-x: auto;
    border-radius: 0.875rem;
    border: 1px solid var(--w4-border);
    background: var(--w4-surface);
  }

  .spots-table {
    width: 100%;
    border-collapse: collapse;
  }

  .spots-table thead tr {
    background: rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid var(--w4-border);
  }

  .spots-table th {
    padding: 0.65rem 1rem;
    text-align: left;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: rgba(229, 231, 235, 0.45);
    white-space: nowrap;
  }

  .spots-table td {
    padding: 0.8rem 1rem;
    border-bottom: 1px solid var(--w4-border);
    vertical-align: middle;
    font-size: 0.9rem;
    color: var(--w4-ink);
  }

  .spots-table tbody tr:last-child td { border-bottom: none; }

  .spots-table tbody tr {
    transition: background 0.1s ease;
    border-left: 3px solid transparent;
  }

  .spots-table tbody tr:hover { background: rgba(255, 255, 255, 0.025); }

  .spots-table tbody tr.spot-active {
    background: rgba(34, 197, 94, 0.06);
    border-left-color: #22c55e;
  }
  .spots-table tbody tr.spot-active:hover { background: rgba(34, 197, 94, 0.1); }

  /* ── Shared element styles ───────────────────────── */
  .spot-active-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #22c55e;
    margin-right: 5px;
    vertical-align: middle;
    flex-shrink: 0;
    animation: pulse-dot 2s infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }

  .spot-name {
    display: block;
    font-weight: 600;
    color: #f3f4f6;
    line-height: 1.3;
  }

  .spot-call {
    display: inline-block;
    font-family: monospace;
    font-size: 0.78rem;
    color: var(--w4-accent) !important;
    text-decoration: none;
  }
  .spot-call:hover { text-decoration: underline; }

  .spot-freq {
    font-family: monospace;
    font-size: 0.9rem;
    color: #f3f4f6;
    white-space: nowrap;
  }

  .spot-band {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    background: rgba(43, 108, 176, 0.3);
    border: 1px solid rgba(43, 108, 176, 0.45);
    color: #93c5fd;
    border-radius: 4px;
    padding: 1px 5px;
    margin-left: 4px;
    vertical-align: middle;
    white-space: nowrap;
  }

  .spot-badge {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    background: rgba(245, 158, 11, 0.12);
    border: 1px solid rgba(245, 158, 11, 0.3);
    color: var(--w4-accent);
    border-radius: 4px;
    padding: 1px 6px;
    white-space: nowrap;
  }

  .spot-muted {
    color: rgba(229, 231, 235, 0.45);
    font-size: 0.84rem;
  }

  .spot-active-time {
    color: #4ade80;
    font-weight: 600;
    font-size: 0.84rem;
  }

  .spot-where { font-size: 0.85rem; color: rgba(229, 231, 235, 0.7); }
  .spot-where a { color: var(--w4-accent) !important; text-decoration: none; }
  .spot-where a:hover { text-decoration: underline; }

  .spots-updated {
    margin-top: 0.6rem;
    font-size: 0.75rem;
    color: rgba(229, 231, 235, 0.35);
    text-align: right;
  }

  /* ── Mobile cards (hidden on desktop) ───────────── */
  .spots-cards {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-direction: column;
    gap: 0.5rem;
  }

  .spot-card {
    background: var(--w4-surface);
    border: 1px solid var(--w4-border);
    border-left: 3px solid transparent;
    border-radius: 0.75rem;
    padding: 0.875rem 1rem;
  }

  .spot-card.spot-active { border-left-color: #22c55e; background: rgba(34,197,94,0.05); }

  .spot-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .spot-card-who { display: flex; align-items: center; gap: 0; flex-wrap: wrap; }

  .spot-card-time {
    font-size: 0.78rem;
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .spot-card-detail {
    margin-top: 0.4rem;
    font-size: 0.82rem;
    color: rgba(229, 231, 235, 0.6);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 0.4rem;
  }

  .spot-card-sep { color: rgba(229, 231, 235, 0.25); }

  .spot-card-where {
    margin-top: 0.3rem;
    font-size: 0.8rem;
    color: rgba(229, 231, 235, 0.6);
  }
  .spot-card-where a { color: var(--w4-accent) !important; text-decoration: none; }

  /* ── Responsive switch ───────────────────────────── */
  @media (max-width: 640px) {
    .spots-scroll { display: none; }
    .spots-cards { display: flex; }
  }

  @media (min-width: 641px) {
    .col-heard th, .col-heard td { /* keep heard col on ≥641 */ }
  }

  /* hide heard-by on narrower desktop too */
  @media (max-width: 820px) {
    .col-heard { display: none; }
  }
</style>

<script>
  // Bundled — astro:page-load fires on initial load + every View Transition.
  const FEED = "https://spots.w4trc.org/spots.json";
  const POLL_MS = 60_000;
  let pollTimer: ReturnType<typeof setInterval> | null = null;

  document.addEventListener("astro:before-swap", () => {
    if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
  });

  document.addEventListener("astro:page-load", () => {
    if (!document.getElementById("spots-board")) return;

    const elLoading = document.getElementById("spots-loading")!;
    const elError   = document.getElementById("spots-error")!;
    const elEmpty   = document.getElementById("spots-empty")!;
    const elWrap    = document.getElementById("spots-wrap")!;
    const elBody    = document.getElementById("spots-body")!;
    const elCards   = document.getElementById("spots-cards")!;
    const elUpdated = document.getElementById("spots-updated")!;
    const elTable   = document.getElementById("spots-table")!;

    const SOURCE_LABELS: Record<string, string> = {
      cluster: "Cluster", rbn: "RBN", pota: "POTA",
      sota: "SOTA", wwff: "WWFF", pskreporter: "PSKr",
    };

    function esc(s: unknown) {
      return String(s ?? "")
        .replace(/&/g, "&amp;").replace(/</g, "&lt;")
        .replace(/>/g, "&gt;").replace(/"/g, "&quot;");
    }

    function relTime(epochSec: number) {
      const diff = Math.floor(Date.now() / 1000) - epochSec;
      if (diff < 60) return "just now";
      if (diff < 3600) return Math.floor(diff / 60) + "m ago";
      if (diff < 86400) return Math.floor(diff / 3600) + "h ago";
      return Math.floor(diff / 86400) + "d ago";
    }

    function isActive(epochSec: number) {
      return Date.now() / 1000 - epochSec < 900;
    }

    function refLink(s: any) {
      if (!s.ref) return null;
      return s.ref_type === "pota"
        ? "https://pota.app/#/park/" + encodeURIComponent(s.ref)
        : s.ref_type === "sota"
          ? "https://sotlas.com/summit/" + encodeURIComponent(s.ref)
          : null;
    }

    function render(spots: any[]) {
      elLoading.hidden = true;
      elError.hidden = true;

      if (!spots.length) {
        elEmpty.hidden = false;
        elWrap.hidden = true;
        return;
      }

      elEmpty.hidden = true;
      elWrap.hidden = false;

      const hasWhere = spots.some((s) => s.ref_type);
      elTable.querySelectorAll(".col-where").forEach((el) => {
        (el as HTMLElement).hidden = !hasWhere;
      });

      // ── Desktop table rows ──────────────────────────
      elBody.innerHTML = spots.map((s) => {
        const member  = esc(s.name || s.callsign);
        const call    = esc(s.callsign);
        const qrz     = "https://www.qrz.com/db/" + encodeURIComponent(s.callsign);
        const freq    = Number(s.frequency).toFixed(3);
        const active  = isActive(s.rx_at);
        const badge   = SOURCE_LABELS[s.source] ?? esc(s.source);
        const spotter = esc(s.spotter || "—");
        const when    = relTime(s.rx_at);

        let whereCell = "";
        if (hasWhere) {
          const href = refLink(s);
          const refText = s.ref_name ? esc(s.ref) + " &middot; " + esc(s.ref_name) : esc(s.ref || "");
          whereCell = `<td class="col-where spot-where">${
            href ? `<a href="${href}" target="_blank" rel="noopener noreferrer">${refText}</a>` : (refText || "—")
          }</td>`;
        }

        return `<tr class="${active ? "spot-active" : ""}">
          <td>
            ${active ? '<span class="spot-active-dot"></span>' : ""}
            <span class="spot-name">${member}</span>
            <a class="spot-call" href="${qrz}" target="_blank" rel="noopener noreferrer">${call}</a>
          </td>
          <td><span class="spot-freq">${freq}&nbsp;MHz</span><span class="spot-band">${esc(s.band)}</span></td>
          <td>${esc(s.mode)}</td>
          <td><span class="spot-badge">${badge}</span></td>
          ${whereCell}
          <td class="col-heard spot-muted">${spotter}</td>
          <td class="${active ? "spot-active-time" : "spot-muted"}">${when}</td>
        </tr>`;
      }).join("");

      // ── Mobile cards ────────────────────────────────
      elCards.innerHTML = spots.map((s) => {
        const member  = esc(s.name || s.callsign);
        const call    = esc(s.callsign);
        const qrz     = "https://www.qrz.com/db/" + encodeURIComponent(s.callsign);
        const freq    = Number(s.frequency).toFixed(3);
        const active  = isActive(s.rx_at);
        const badge   = SOURCE_LABELS[s.source] ?? esc(s.source);
        const when    = relTime(s.rx_at);

        const timeClass = active ? "spot-active-time" : "spot-muted";

        let whereRow = "";
        if (s.ref_type && s.ref) {
          const href = refLink(s);
          const refText = s.ref_name ? esc(s.ref) + " · " + esc(s.ref_name) : esc(s.ref);
          whereRow = `<p class="spot-card-where">${
            href ? `<a href="${href}" target="_blank" rel="noopener noreferrer">${refText}</a>` : refText
          }</p>`;
        }

        return `<li class="spot-card${active ? " spot-active" : ""}">
          <div class="spot-card-header">
            <div class="spot-card-who">
              ${active ? '<span class="spot-active-dot"></span>' : ""}
              <span class="spot-name">${member}</span>
              <a class="spot-call" href="${qrz}" target="_blank" rel="noopener noreferrer">&nbsp;${call}</a>
            </div>
            <span class="spot-card-time ${timeClass}">${when}</span>
          </div>
          <div class="spot-card-detail">
            <span class="spot-freq">${freq}&nbsp;MHz</span>
            <span class="spot-band">${esc(s.band)}</span>
            <span class="spot-card-sep">·</span>
            <span>${esc(s.mode)}</span>
            <span class="spot-card-sep">·</span>
            <span class="spot-badge">${badge}</span>
          </div>
          ${whereRow}
        </li>`;
      }).join("");

      elUpdated.textContent =
        "Updated " + new Date().toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" });
    }

    async function load() {
      try {
        const res = await fetch(FEED);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const raw = await res.json();

        const spots: any[] = Array.isArray(raw) ? raw
          : Array.isArray(raw?.spots) ? raw.spots
          : Array.isArray(raw?.data)  ? raw.data
          : [];

        if (!Array.isArray(raw)) {
          console.warn("[SpotsBoard] Unexpected response shape:", raw);
        }

        render(spots);
      } catch (err) {
        console.error("[SpotsBoard] fetch failed:", FEED, err);
        elLoading.hidden = true;
        elError.hidden = false;
      }
    }

    load();
    pollTimer = setInterval(load, POLL_MS);
  });
</script>
